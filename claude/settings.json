{
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "PostToolUseFailure": [
      {
        "matcher": "Read|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nono-hook.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "financial-analysis@financial-services-plugins": true,
    "investment-banking@financial-services-plugins": true,
    "equity-research@financial-services-plugins": true,
    "private-equity@financial-services-plugins": true,
    "wealth-management@financial-services-plugins": true,
    "typescript-lsp@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "asana@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "clangd-lsp@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "firebase@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "gitlab@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "greptile@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": true,
    "linear@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "php-lsp@claude-plugins-official": false,
    "pinecone@claude-plugins-official": false,
    "playground@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "stripe@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "vercel@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "financial-services-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/financial-services-plugins"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "outputStyle": "Explanatory",
  "language": "ja",
  "autoUpdatesChannel": "latest",
  "showTurnDuration": true,
  "skipDangerousModePermissionPrompt": true
}
